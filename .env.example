# ── Web (apps/web) — copy needed vars to apps/web/.env.local ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Worker (apps/worker) — copy needed vars to apps/worker/.env ─────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY — same as above
# INNGEST_EVENT_KEY / INNGEST_SIGNING_KEY — same as above
ANTHROPIC_API_KEY=sk-ant-xxx
# SENTRY_DSN — worker has its own Sentry project DSN
